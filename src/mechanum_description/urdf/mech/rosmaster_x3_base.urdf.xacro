<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ═══════════════════════════════════════════════════════════
       Dimensions réelles de votre robot (à ajuster si besoin)
       Châssis : 52cm x 40cm x 10cm  — noir
       Roues    : rayon 3.25cm, largeur 3cm
       Mâts     : 2 cylindres noirs
       Plateforme + bacs bleus
  ═══════════════════════════════════════════════════════════ -->

  <!-- Châssis -->
  <xacro:property name="base_length"    value="0.520" />
  <xacro:property name="base_width"     value="0.400" />
  <xacro:property name="base_height"    value="0.100" />
  <xacro:property name="base_mass"      value="5.0"   />

  <!-- Roues -->
  <xacro:property name="wheel_radius"   value="0.0325" />
  <xacro:property name="wheel_width"    value="0.0304" />

  <!-- Mâts -->
  <xacro:property name="pole_radius"    value="0.018"  />
  <xacro:property name="pole_height"    value="0.60"   />
  <xacro:property name="pole_mass"      value="0.15"   />

  <!-- Plateforme supérieure -->
  <xacro:property name="shelf_length"   value="0.38"   />
  <xacro:property name="shelf_width"    value="0.30"   />
  <xacro:property name="shelf_thick"    value="0.008"  />

  <!-- Bacs bleus -->
  <xacro:property name="bin_length"     value="0.36"   />
  <xacro:property name="bin_width"      value="0.28"   />
  <xacro:property name="bin_height"     value="0.15"   />
  <xacro:property name="bin_mass"       value="0.3"    />

  <!-- Offsets calculés -->
  <xacro:property name="pole_z"         value="${base_height + pole_height/2}" />
  <xacro:property name="shelf_z"        value="${base_height + pole_height}" />
  <xacro:property name="bin_z"          value="${shelf_z + shelf_thick/2 + bin_height/2}" />

  <!-- Macros inertie -->
  <xacro:macro name="box_inertia" params="m l w h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(w*w+h*h)/12}" ixy="0" ixz="0"
               iyy="${m*(l*l+h*h)/12}" iyz="0"
               izz="${m*(l*l+w*w)/12}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cyl_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+h*h)/12}" ixy="0" ixz="0"
               iyy="${m*(3*r*r+h*h)/12}" iyz="0"
               izz="${m*r*r/2}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="rosmaster_x3_base">

    <!-- ── base_footprint (frame sol) ── -->
    <link name="base_footprint"/>

    <!-- ── Châssis principal ── -->
    <link name="base_link">
      <visual>
        <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
        <geometry>
          <box size="${base_length} ${base_width} ${base_height}"/>
        </geometry>
        <material name="mat_black">
          <color rgba="0.08 0.08 0.08 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
        <geometry>
          <box size="${base_length} ${base_width} ${base_height}"/>
        </geometry>
      </collision>
      <xacro:box_inertia m="${base_mass}" l="${base_length}" w="${base_width}" h="${base_height}"/>
    </link>
    <gazebo reference="base_link">
      <material>Gazebo/Black</material>
    </gazebo>

    <joint name="base_joint" type="fixed">
      <parent link="base_footprint"/>
      <child  link="base_link"/>
      <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
    </joint>

    <!-- ── Mât gauche ── -->
    <link name="pole_left_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${pole_radius}" length="${pole_height}"/>
        </geometry>
        <material name="mat_gray">
          <color rgba="0.3 0.3 0.3 1.0"/>
        </material>
      </visual>
      <collision>
        <geometry><cylinder radius="${pole_radius}" length="${pole_height}"/></geometry>
      </collision>
      <xacro:cyl_inertia m="${pole_mass}" r="${pole_radius}" h="${pole_height}"/>
    </link>
    <joint name="pole_left_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="pole_left_link"/>
      <origin xyz="-0.08 0.12 ${pole_z}" rpy="0 0 0"/>
    </joint>
    <gazebo reference="pole_left_link"><material>Gazebo/Grey</material></gazebo>

    <!-- ── Mât droit ── -->
    <link name="pole_right_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${pole_radius}" length="${pole_height}"/>
        </geometry>
        <material name="mat_gray">
          <color rgba="0.3 0.3 0.3 1.0"/>
        </material>
      </visual>
      <collision>
        <geometry><cylinder radius="${pole_radius}" length="${pole_height}"/></geometry>
      </collision>
      <xacro:cyl_inertia m="${pole_mass}" r="${pole_radius}" h="${pole_height}"/>
    </link>
    <joint name="pole_right_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="pole_right_link"/>
      <origin xyz="-0.08 -0.12 ${pole_z}" rpy="0 0 0"/>
    </joint>
    <gazebo reference="pole_right_link"><material>Gazebo/Grey</material></gazebo>

    <!-- ── Plateforme intermédiaire (plaque noire) ── -->
    <link name="shelf_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${shelf_length} ${shelf_width} ${shelf_thick}"/>
        </geometry>
        <material name="mat_darkgray">
          <color rgba="0.2 0.2 0.2 1.0"/>
        </material>
      </visual>
      <collision>
        <geometry><box size="${shelf_length} ${shelf_width} ${shelf_thick}"/></geometry>
      </collision>
      <xacro:box_inertia m="0.3" l="${shelf_length}" w="${shelf_width}" h="${shelf_thick}"/>
    </link>
    <joint name="shelf_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="shelf_link"/>
      <origin xyz="0 0 ${shelf_z}" rpy="0 0 0"/>
    </joint>
    <gazebo reference="shelf_link"><material>Gazebo/DarkGray</material></gazebo>

    <!-- ── Bacs bleus (plateforme supérieure) ── -->
    <link name="bins_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${bin_length} ${bin_width} ${bin_height}"/>
        </geometry>
        <material name="mat_blue">
          <color rgba="0.05 0.25 0.80 1.0"/>
        </material>
      </visual>
      <collision>
        <geometry><box size="${bin_length} ${bin_width} ${bin_height}"/></geometry>
      </collision>
      <xacro:box_inertia m="${bin_mass}" l="${bin_length}" w="${bin_width}" h="${bin_height}"/>
    </link>
    <joint name="bins_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="bins_link"/>
      <origin xyz="0 0 ${bin_z}" rpy="0 0 0"/>
    </joint>
    <gazebo reference="bins_link"><material>Gazebo/Blue</material></gazebo>

  </xacro:macro>
</robot>