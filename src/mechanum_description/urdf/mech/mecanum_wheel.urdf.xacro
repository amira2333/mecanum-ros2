<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="wheel_radius"    value="0.0325" />
  <xacro:property name="wheel_separation" value="0.169" />
  <xacro:property name="wheel_width"     value="0.0304" />
  <xacro:property name="wheel_mass"      value="0.5"    />
  <xacro:property name="wheel_xoff"      value="0.08"   />
  <xacro:property name="wheel_yoff"      value="-0.01"  />

  <xacro:macro name="mecanum_wheel" params="side x_reflect y_reflect">

    <link name="${side}_wheel_link">
      <!-- CORRECTION : cylindre géométrique simple au lieu du mesh STL rosmaster_x3
           Couleur noir foncé pour les roues mecanum -->
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="mat_wheel">
          <color rgba="0.15 0.15 0.15 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="${wheel_mass}"/>
        <inertia
          ixx="${(wheel_mass/12.0)*(3*wheel_radius*wheel_radius + wheel_width*wheel_width)}"
          ixy="0" ixz="0"
          iyy="${(wheel_mass/2.0)*(wheel_radius*wheel_radius)}"
          iyz="0"
          izz="${(wheel_mass/12.0)*(3*wheel_radius*wheel_radius + wheel_width*wheel_width)}"/>
      </inertial>
    </link>

    <joint name="${side}_wheel_joint" type="continuous">
      <axis xyz="0 1 0"/>
      <parent link="base_link"/>
      <child  link="${side}_wheel_link"/>
      <origin xyz="${x_reflect*wheel_xoff} ${y_reflect*(wheel_separation/2+wheel_yoff)} ${-wheel_radius}" rpy="0 0 0"/>
    </joint>

    <!-- Friction mecanum : mu1 fort (avance), mu2 faible (dérive latérale) -->
    <gazebo reference="${side}_wheel_link">
      <collision>
        <surface>
          <friction>
            <ode>
              <mu1>0.8</mu1>
              <mu2>0.2</mu2>
              <minDepth>0.001</minDepth>
              <fdir1>
                <xacro:if value="${side == 'front_left'}">1 -1 0</xacro:if>
                <xacro:if value="${side == 'back_left'}">1 1 0</xacro:if>
                <xacro:if value="${side == 'front_right'}">1 1 0</xacro:if>
                <xacro:if value="${side == 'back_right'}">1 -1 0</xacro:if>
              </fdir1>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual>
        <material>
          <ambient>0.15 0.15 0.15 1.0</ambient>
          <diffuse>0.15 0.15 0.15 1.0</diffuse>
          <specular>0.1  0.1  0.1  1.0</specular>
        </material>
      </visual>
    </gazebo>

  </xacro:macro>
</robot>